      │
      ├──────────────┐
      │              │
      ▼              ▼
Car1            Car2
Red             Blue
BMW             Audi

Car Class → Blueprint
Car1, Car2 → Objects

---------------------------------------------
class ClassName {
    // Fields (Variables)
    // Constructors
    // Methods
}
---------------------------------------------
class Student {            // Student Class
    String name;           // instance variable
    int age;              // instance variable
    void study() {        // Method
