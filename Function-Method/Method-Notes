=========================
| Varargs (...) in Java |
=========================
👉 Varargs (Variable Arguments) allow a method to accept a variable number of arguments of the same type.
   👉 Introduced in Java 5.
   👉 Uses three dots (...).
   👉 Allows passing zero or more arguments.
   👉 Internally works as an array.
   👉 A method can have only one varargs parameter.
   👉 Varargs must be the last parameter.

   returnType methodName(dataType... variableName)
   {
       // code
   }
--------------------------------------------------- // Simple Varargs
public class Main {
    public static void show(int... numbers) {
        for(int n : numbers) {
            System.out.println(n);
        }
    }

    public static void main(String[] args) {
        show(10,20,30);
    }
}
---------------------------------------------------- // Sum of Numbers
public class Main {
    public static int sum(int... numbers) {
        int total = 0;
        for(int n : numbers) {
            total += n;
        }
        return total;
    }

    public static void main(String[] args) {
        System.out.println(sum(10,20));
        System.out.println(sum(10,20,30));
        System.out.println(sum(1,2,3,4,5));
    }
}
------------------------------------------------------ // Varargs with Normal Parameter
public class Main {
    public static void student(String name, int... marks) {
        System.out.println(name);
        for(int m : marks) {
            System.out.println(m);
        }
    }

    public static void main(String[] args) {
        student("Mridul",90,85,95);
    }
}
