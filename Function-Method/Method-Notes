public static void greet(String name)
{
    System.out.println("Hello " + name);
}

String name -> Parameter
"Mridul" ->  Argument
greet("Mridul"); -> Method Call

Parameter vs Argument
----------------------
_____________________________________________________________
| Parameter                     | Argument                  |
| ----------------------------- | ------------------------- |
| Declared in method definition | Passed during method call |
| Variable                      | Actual value              |
| Receives data                 | Sends data                |
-------------------------------------------------------------

public class Main {
    public static void add(int a, int b) {    // Multiple Parameters
        System.out.println(a + b);
    }

    public static void main(String[] args) {
        add(10, 20);
    }
}
-------------------------------------------------------------  // Different Data Types
public class Main {
    public static void student(String name, int age, double marks) {
        System.out.println("Name : " + name);
        System.out.println("Age : " + age);
        System.out.println("Marks : " + marks);
    }

    public static void main(String[] args) {
        student("Aman", 18, 89.5);
    }
}
